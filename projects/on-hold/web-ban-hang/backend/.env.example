# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
# MongoDB connection string
# Local: mongodb://localhost:27017/web-ban-hang
# Atlas: mongodb+srv://<username>:<password>@cluster.mongodb.net/web-ban-hang
MONGO_URI=mongodb://localhost:27017/web-ban-hang

# JWT Configuration
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRE=24h

# Client Configuration
CLIENT_URL=http://localhost:3000
